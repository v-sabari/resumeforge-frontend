# ════════════════════════════════════════════════════
#  ResumeForge AI — Frontend Environment Variables
#  Copy to .env and fill in your real values
# ════════════════════════════════════════════════════

# ── Backend API URL ──────────────────────────────────
# No trailing slash. Use http://localhost:8080 for local dev.
VITE_API_BASE_URL=https://your-backend.onrender.com

# ── App name ─────────────────────────────────────────
VITE_APP_NAME=ResumeForge AI

# ── Razorpay ─────────────────────────────────────────
# Public key ID only — never put secret in frontend
VITE_RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXXXXXX
VITE_RAZORPAY_LINK=https://rzp.io/rzp/YOUR_LINK_ID

# ── Google Analytics 4 ───────────────────────────────
# Get from: GA4 → Admin → Data Streams → Measurement ID
# Format: G-XXXXXXXXXX
VITE_GA4_ID=G-XXXXXXXXXX

# ── Google AdSense ────────────────────────────────────
# Only add after AdSense approval. Format: ca-pub-XXXXXXXXXXXXXXXX
VITE_ADSENSE_CLIENT=
# Ad slot IDs — get from AdSense → Ads → Ad units
VITE_ADSENSE_SLOT_CONTENT=
