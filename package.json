{
  "name": "resumeforge-ai-frontend",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && react-snap",
    "build:csr": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext js,jsx --max-warnings 0"
  },
  "dependencies": {
    "axios": "^1.8.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@types/react": "^18.3.21",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.24.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "postcss": "^8.5.3",
    "react-snap": "^1.23.0",
    "tailwindcss": "^3.4.17",
    "vite": "^5.4.18"
  },
  "reactSnap": {
    "source": "dist",
    "destination": "dist",
    "publicPath": "/",
    "include": [
      "/",
      "/pricing",
      "/about",
      "/contact",
      "/terms",
      "/privacy",
      "/refund-policy",
      "/resources",
      "/tools",
      "/tools/linkedin",
      "/tools/ats-score",
      "/login",
      "/register",
      "/forgot-password",
      "/reset-password",
      "/verify-email"
    ],
    "puppeteerArgs": [
      "--no-sandbox",
      "--disable-setuid-sandbox"
    ],
    "puppeteerExecutablePath": "C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe",
    "inlineCss": false,
    "minifyHtml": false,
    "crawl": false
  }
}
