    {
      "source": "/login",
      "destination": "/"
    },
    {
      "source": "/register",
      "destination": "/"
    },
    {
      "source": "/verify-email",
      "destination": "/"
    },
    {
      "source": "/forgot-password",
      "destination": "/"
    },
    {
      "source": "/reset-password",
      "destination": "/"
    },
    {
      "source": "/payment/success",
